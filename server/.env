# Server
PORT=4000
CLIENT_URL=http://localhost:3000

# MySQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lukibou_db

# JWT
JWT_SECRET=lukibou_dev_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# 訂單 webhook 密鑰（需與 web/.env.local 的 ORDER_WEBHOOK_SECRET 相同）
ORDER_WEBHOOK_SECRET=lukibou_order_webhook_dev_secret
