# Server
PORT=4000
CLIENT_URL=http://localhost:3000

# MySQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lukibou_db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=8h

# 訂單 webhook 密鑰（需與 web/.env.local 的 ORDER_WEBHOOK_SECRET 相同）
ORDER_WEBHOOK_SECRET=change_this_order_webhook_secret
