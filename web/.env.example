# Stripe（從 https://dashboard.stripe.com/test/apikeys 取得）
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Webhook（本地開發用 Stripe CLI：stripe listen --forward-to localhost:3000/api/webhooks/stripe）
STRIPE_WEBHOOK_SECRET=whsec_...

# 網站網址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 過渡期：Express 仍處理訂單 webhook、收藏、地址簿等（可選）
NEXT_PUBLIC_API_URL=http://localhost:4000

ORDER_WEBHOOK_SECRET=change_this_order_webhook_secret

# ── Supabase / Postgres（Prisma）──
# Transaction pooler（應用程式連線，port 6543 + pgbouncer=true）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true

# Session pooler 或直連（prisma db push / migrate 用，port 5432）
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# JWT（會員與管理員 token）
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
